{
  "manifest_version": 3,
  "name": "ChromaPro: Color Picker",
  "version": "1.0.2",
  "description": "A precise color picker for designers and developers. Sample any pixel on your screen and save your color history locally.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
